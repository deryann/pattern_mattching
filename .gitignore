# --- uv ---
# Keep uv.lock committed for reproducibility; ignore uv's local caches only.
.uv/
uv-cache/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.hypothesis/
.ruff_cache/
.mypy_cache/

# --- Editors / OS ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Secrets / local config ---
.env
.env.*
!.env.example

# --- Logs ---
*.log
logs/

# --- Project-specific ---
# Playwright MCP snapshots / console dumps (generated during e2e runs)
.playwright-mcp/

# Generated HTML / preview outputs
outputs/

# User-uploaded or experimental images (keep curated test_image/ tracked)
uploads/
tmp/
